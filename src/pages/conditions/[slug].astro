---
import fs from 'node:fs';
import path from 'node:path';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AppointmentForm from '../../components/AppointmentForm.astro';
import CTASection from '../../components/CTASection.astro';
import { conditions } from '../../data/conditions';
import { treatments } from '../../data/treatments';
import { locations } from '../../data/locations';

export const getStaticPaths: GetStaticPaths = async () => {
  return conditions.map(condition => ({
    params: { slug: condition.slug },
    props: { condition },
  }));
};

const { condition } = Astro.props;

const relatedTreatmentData = treatments.filter(t => condition.relatedTreatments.includes(t.slug));
const relatedLocationData  = locations.filter(l => condition.relatedLocations.includes(l.slug));

const imagesDir = path.join(process.cwd(), 'public/images/conditions');
const conditionImages = fs.existsSync(imagesDir)
  ? fs.readdirSync(imagesDir)
      .filter(f => new RegExp(`^${condition.slug}-\\d+\\.webp$`).test(f))
      .sort()
      .map(f => `/images/conditions/${f}`)
  : [];

const conditionSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalCondition',
  name: condition.name,
  description: condition.schemaDescription,
  associatedAnatomy: { '@type': 'AnatomicalStructure', name: 'Spine and Musculoskeletal System' },
  signOrSymptom: condition.symptoms.map(s => ({ '@type': 'MedicalSymptom', name: s })),
  possibleTreatment: relatedTreatmentData.map(t => ({ '@type': 'MedicalProcedure', name: t.name })),
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: condition.faq.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

function renderBody(text: string): string {
  const applyInline = (s: string) =>
    s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
     .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
  return text
    .split('\n\n')
    .map(para => {
      const trimmed = para.trim();
      if (trimmed.startsWith('<')) return trimmed;
      if (/^\*\*[^*\n]+\*\*$/.test(trimmed)) return `<h3>${trimmed.slice(2, -2)}</h3>`;
      if (/^\d+\.\s/.test(trimmed)) {
        const items = trimmed.split('\n').filter(l => /^\d+\.\s/.test(l.trim()))
          .map(l => `<li>${applyInline(l.replace(/^\d+\.\s/, ''))}</li>`).join('');
        return `<ol>${items}</ol>`;
      }
      if (trimmed.startsWith('- ')) {
        const items = trimmed.split('\n').filter(l => l.trim().startsWith('- '))
          .map(l => `<li>${applyInline(l.trim().slice(2))}</li>`).join('');
        return `<ul>${items}</ul>`;
      }
      return `<p>${applyInline(para)}</p>`;
    })
    .join('');
}
---

<BaseLayout
  title={condition.metaTitle}
  description={condition.metaDescription}
  schema={[conditionSchema, faqSchema]}
>
  <!-- Breadcrumbs -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Breadcrumbs crumbs={[
      { label: 'Conditions', href: '/conditions/' },
      { label: condition.name },
    ]} />
  </div>

  <!-- Hero -->
  <section
    class="py-14 md:py-18"
    style="background:linear-gradient(135deg,#0a4a50,#0E5C63,#147078)"
    aria-labelledby="condition-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block text-sm font-medium text-teal-200 mb-3">Pain Condition · Dallas, TX</span>
        <h1 id="condition-heading" class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
          {condition.heroHeading}
        </h1>
        <p class="text-xl text-teal-100 leading-relaxed mb-8">{condition.heroSubheading}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/request-appointment/" class="btn-primary py-4 px-8">
            Request Appointment
          </a>
          <a href="tel:+12145550100" class="btn-white py-4 px-8">
            <svg class="w-5 h-5 text-teal-700" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            (214) 555-0100
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-3 gap-12">

      <!-- Article body -->
      <article class="lg:col-span-2">
        <!-- Intro -->
        <div class="text-xl text-slate-700 leading-relaxed mb-8 pb-8 border-b border-slate-100 font-light">
          {condition.intro}
        </div>

        <!-- Symptoms quick list -->
        <div class="card p-6 mb-8">
          <h2 class="text-lg font-bold text-slate-900 mb-4">Common Symptoms</h2>
          <ul class="grid sm:grid-cols-2 gap-2">
            {condition.symptoms.map(s => (
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <svg class="w-4 h-4 text-teal-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {s}
              </li>
            ))}
          </ul>
        </div>

        <!-- Body content -->
        <div class="prose-medical" set:html={renderBody(condition.body)} />

        {conditionImages.length > 0 && (
          <div class={`grid gap-6 my-8 ${conditionImages.length > 1 ? 'sm:grid-cols-2' : ''}`}>
            {conditionImages.map((src, i) => (
              <img
                src={src}
                alt={`${condition.name} treatment in Dallas, TX — Dallas Pain Help${conditionImages.length > 1 ? ` (${i + 1} of ${conditionImages.length})` : ''}`}
                class="rounded-2xl w-full h-auto shadow-sm"
                width="1080"
                height="1080"
                loading="lazy"
                decoding="async"
              />
            ))}
          </div>
        )}

        <!-- Related Treatments -->
        {relatedTreatmentData.length > 0 && (
          <section aria-labelledby="rel-treatments-heading" class="mt-12">
            <h2 id="rel-treatments-heading" class="text-2xl font-bold text-slate-900 mb-5">
              Treatments for {condition.name} in Dallas
            </h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {relatedTreatmentData.map(t => (
                <a href={`/treatments/${t.slug}/`} class="card p-5 flex items-start gap-3 group">
                  <div
                    class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
                    style="background:linear-gradient(135deg,#0E5C63,#1A8A99)"
                  >
                    <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-slate-900 group-hover:text-teal-700 transition-colors text-sm">{t.name}</h3>
                    <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">{t.intro.slice(0, 80)}…</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- FAQ -->
        <section aria-labelledby="faq-heading" class="mt-12">
          <h2 id="faq-heading" class="text-2xl font-bold text-slate-900 mb-5">
            Frequently Asked Questions about {condition.name} in Dallas
          </h2>
          <div class="space-y-3">
            {condition.faq.map((item, i) => (
              <details class="card group" id={`faq-cond-${i}`}>
                <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none font-semibold text-slate-800 hover:text-teal-700 transition-colors select-none">
                  {item.question}
                  <svg class="w-5 h-5 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-slate-600 text-sm leading-relaxed border-t border-slate-100 pt-4">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </section>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <!-- Quick appointment form -->
        <div class="card p-6 sticky top-24">
          <AppointmentForm
            heading="Request Appointment"
            subheading="Same-day availability. Confirm within 1 hour."
            compact={true}
          />
        </div>

        <!-- Locations -->
        {relatedLocationData.length > 0 && (
          <div class="card p-5">
            <h3 class="font-bold text-slate-900 mb-3 text-sm">Serving These Dallas Areas</h3>
            <ul class="space-y-2">
              {relatedLocationData.map(l => (
                <li>
                  <a href={`/locations/${l.slug}/`} class="flex items-center gap-2 text-sm text-slate-600 hover:text-teal-700 transition-colors">
                    <svg class="w-3.5 h-3.5 text-teal-400 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                    Pain Management in {l.name}, TX
                  </a>
                </li>
              ))}
              <li class="pt-1">
                <a href="/locations/" class="text-xs text-teal-600 hover:text-teal-700 font-medium">View all locations →</a>
              </li>
            </ul>
          </div>
        )}

        <!-- Trust block -->
        <div style="background:linear-gradient(135deg,#0E5C63,#1A8A99)" class="rounded-2xl p-5 text-white">
          <h3 class="font-bold mb-3 text-sm">Why Choose Dallas Pain Help?</h3>
          <ul class="space-y-2.5">
            {['Board-certified pain specialists', 'Same-day appointments available', 'Most insurance accepted', 'Minimally invasive approach', 'Bilingual care (EN/ES)'].map(item => (
              <li class="flex items-center gap-2 text-sm text-teal-100">
                <svg class="w-4 h-4 text-coral-400 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="tel:+12145550100" class="btn-white mt-4 w-full justify-center text-sm py-3">
            Call (214) 555-0100
          </a>
        </div>
      </aside>
    </div>
  </div>

  <CTASection heading={`Get Relief from ${condition.name} in Dallas`} />
</BaseLayout>
