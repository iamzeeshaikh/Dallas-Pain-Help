---
import fs from 'node:fs';
import path from 'node:path';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AppointmentForm from '../../components/AppointmentForm.astro';
import CTASection from '../../components/CTASection.astro';
import { treatments } from '../../data/treatments';
import { conditions } from '../../data/conditions';
import { locations } from '../../data/locations';

export const getStaticPaths: GetStaticPaths = async () => {
  return treatments.map(treatment => ({
    params: { slug: treatment.slug },
    props: { treatment },
  }));
};

const { treatment } = Astro.props;

const relatedConditionData   = conditions.filter(c => treatment.conditions.includes(c.slug));
const relatedTreatmentData   = treatments.filter(t => treatment.relatedTreatments.includes(t.slug));
const relatedLocationData    = locations.filter(l => treatment.relatedLocations.includes(l.slug));

const imagesDir = path.join(process.cwd(), 'public/images/treatments');
const treatmentImages = fs.existsSync(imagesDir)
  ? fs.readdirSync(imagesDir)
      .filter(f => new RegExp(`^${treatment.slug}-\\d+\\.webp$`).test(f))
      .sort()
      .map(f => `/images/treatments/${f}`)
  : [];

const procedureSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  name: treatment.name,
  description: treatment.schemaDescription,
  procedureType: 'https://schema.org/TherapeuticProcedure',
  followup: 'Follow-up as directed by your physician',
  indication: relatedConditionData.map(c => ({ '@type': 'MedicalIndication', name: c.name })),
  bodyLocation: 'Spine and Musculoskeletal System',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: treatment.faq.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

function renderBody(text: string): string {
  const applyInline = (s: string) =>
    s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
     .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
  return text
    .split('\n\n')
    .map(para => {
      const trimmed = para.trim();
      if (trimmed.startsWith('<')) return trimmed;
      if (/^\*\*[^*\n]+\*\*$/.test(trimmed)) return `<h3>${trimmed.slice(2, -2)}</h3>`;
      if (/^\d+\.\s/.test(trimmed)) {
        const items = trimmed.split('\n').filter(l => /^\d+\.\s/.test(l.trim()))
          .map(l => `<li>${applyInline(l.replace(/^\d+\.\s/, ''))}</li>`).join('');
        return `<ol>${items}</ol>`;
      }
      if (trimmed.startsWith('- ')) {
        const items = trimmed.split('\n').filter(l => l.trim().startsWith('- '))
          .map(l => `<li>${applyInline(l.trim().slice(2))}</li>`).join('');
        return `<ul>${items}</ul>`;
      }
      return `<p>${applyInline(para)}</p>`;
    })
    .join('');
}
---

<BaseLayout
  title={treatment.metaTitle}
  description={treatment.metaDescription}
  schema={[procedureSchema, faqSchema]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <Breadcrumbs crumbs={[
      { label: 'Treatments', href: '/treatments/' },
      { label: treatment.name },
    ]} />
  </div>

  <!-- Hero -->
  <section
    class="py-14 md:py-18"
    style="background:linear-gradient(135deg,#0a4a50,#0E5C63,#1A8A99)"
    aria-labelledby="treatment-heading"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block text-sm font-medium text-teal-200 mb-3">Pain Treatment · Dallas, TX</span>
        <h1 id="treatment-heading" class="text-4xl md:text-5xl font-bold text-white leading-tight mb-4">
          {treatment.heroHeading}
        </h1>
        <p class="text-xl text-teal-100 leading-relaxed mb-8">{treatment.heroSubheading}</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/request-appointment/" class="btn-primary py-4 px-8">Request Appointment</a>
          <a href="tel:+12145550100" class="btn-white py-4 px-8">
            <svg class="w-5 h-5 text-teal-700" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
            </svg>
            (214) 555-0100
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-3 gap-12">

      <article class="lg:col-span-2">
        <!-- Intro -->
        <div class="text-xl text-slate-700 leading-relaxed mb-8 pb-8 border-b border-slate-100 font-light">
          {treatment.intro}
        </div>

        <!-- Benefits -->
        <div class="card p-6 mb-8">
          <h2 class="text-lg font-bold text-slate-900 mb-4">Benefits of {treatment.shortName}</h2>
          <ul class="grid sm:grid-cols-2 gap-2">
            {treatment.benefits.map(b => (
              <li class="flex items-start gap-2 text-sm text-slate-700">
                <svg class="w-4 h-4 text-teal-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {b}
              </li>
            ))}
          </ul>
        </div>

        <!-- Body -->
        <div class="prose-medical" set:html={renderBody(treatment.body)} />

        {treatmentImages.length > 0 && (
          <div class={`grid gap-6 my-8 ${treatmentImages.length > 1 ? 'sm:grid-cols-2' : ''}`}>
            {treatmentImages.map((src, i) => (
              <img
                src={src}
                alt={`${treatment.name} at Dallas Pain Help, Dallas TX${treatmentImages.length > 1 ? ` (${i + 1} of ${treatmentImages.length})` : ''}`}
                class="rounded-2xl w-full h-auto shadow-sm"
                width="1080"
                height="1080"
                loading="lazy"
                decoding="async"
              />
            ))}
          </div>
        )}

        <!-- Related Conditions -->
        {relatedConditionData.length > 0 && (
          <section aria-labelledby="rel-conditions-heading" class="mt-12">
            <h2 id="rel-conditions-heading" class="text-2xl font-bold text-slate-900 mb-5">
              Conditions Treated with {treatment.shortName}
            </h2>
            <div class="grid sm:grid-cols-2 gap-3">
              {relatedConditionData.map(c => (
                <a href={`/conditions/${c.slug}/`} class="card p-4 flex items-center gap-3 group">
                  <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background:#e0f5f7">
                    <svg class="w-4 h-4 text-teal-700" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
                    </svg>
                  </div>
                  <span class="text-sm font-medium text-slate-700 group-hover:text-teal-700 transition-colors">{c.name}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- FAQ -->
        <section aria-labelledby="faq-tx-heading" class="mt-12">
          <h2 id="faq-tx-heading" class="text-2xl font-bold text-slate-900 mb-5">
            {treatment.shortName} — Frequently Asked Questions
          </h2>
          <div class="space-y-3">
            {treatment.faq.map((item, i) => (
              <details class="card group" id={`faq-tx-${i}`}>
                <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none font-semibold text-slate-800 hover:text-teal-700 transition-colors select-none">
                  {item.question}
                  <svg class="w-5 h-5 text-slate-400 shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="px-5 pb-5 text-slate-600 text-sm leading-relaxed border-t border-slate-100 pt-4">
                  {item.answer}
                </div>
              </details>
            ))}
          </div>
        </section>
      </article>

      <!-- Sidebar -->
      <aside class="space-y-6">
        <div class="card p-6 sticky top-24">
          <AppointmentForm
            heading="Schedule This Treatment"
            subheading="Same-day availability. Confirm within 1 hour."
            compact={true}
          />
        </div>

        {relatedTreatmentData.length > 0 && (
          <div class="card p-5">
            <h3 class="font-bold text-slate-900 mb-3 text-sm">Related Treatments</h3>
            <ul class="space-y-2">
              {relatedTreatmentData.map(t => (
                <li>
                  <a href={`/treatments/${t.slug}/`} class="text-sm text-slate-600 hover:text-teal-700 transition-colors flex items-center gap-1.5">
                    <svg class="w-3 h-3 text-teal-400 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {t.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        {relatedLocationData.length > 0 && (
          <div class="card p-5">
            <h3 class="font-bold text-slate-900 mb-3 text-sm">Available Near You</h3>
            <ul class="space-y-2">
              {relatedLocationData.map(l => (
                <li>
                  <a href={`/locations/${l.slug}/`} class="flex items-center gap-2 text-sm text-slate-600 hover:text-teal-700 transition-colors">
                    <svg class="w-3.5 h-3.5 text-teal-400 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                    {l.name}, TX
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div style="background:linear-gradient(135deg,#0E5C63,#1A8A99)" class="rounded-2xl p-5 text-white">
          <h3 class="font-bold mb-3 text-sm">Ready to Get Started?</h3>
          <ul class="space-y-2.5 mb-4">
            {['Same-day available', 'Board-certified physicians', 'Most insurance accepted'].map(item => (
              <li class="flex items-center gap-2 text-sm text-teal-100">
                <svg class="w-4 h-4 text-coral-400 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="tel:+12145550100" class="btn-white w-full justify-center text-sm py-3">
            Call (214) 555-0100
          </a>
        </div>
      </aside>
    </div>
  </div>

  <CTASection heading={`Schedule Your ${treatment.shortName} in Dallas`} />
</BaseLayout>
