---
import { conditions } from '../data/conditions';
import { treatments } from '../data/treatments';
import { locations } from '../data/locations';

const phone = '(214) 555-0100';
const phoneHref = 'tel:+12145550100';
// TODO: Replace with real clinic phone number before launch
---

<header
  id="site-header"
  class="sticky top-0 z-40 w-full bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-sm shadow-slate-100/50"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Dallas Pain Help — Home">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center" style="background:linear-gradient(135deg,#0E5C63,#1A8A99)">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="white"/>
          </svg>
        </div>
        <div class="leading-tight">
          <span class="font-bold text-teal-800 text-lg tracking-tight">Dallas</span><span class="font-bold text-coral-500 text-lg tracking-tight">Pain</span><span class="font-bold text-teal-800 text-lg tracking-tight">Help</span>
        </div>
      </a>

      <!-- ── Desktop nav with dropdowns ── -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">

        <!-- Conditions dropdown -->
        <div class="relative group/cond">
          <a
            href="/conditions/"
            class="flex items-center gap-1 px-3.5 py-2 rounded-lg text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors"
            aria-haspopup="menu"
          >
            Conditions
            <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200 group-hover/cond:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
          <!-- Conditions mega-panel -->
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/cond:opacity-100 group-hover/cond:visible transition-all duration-150 ease-out z-50" style="min-width:540px">
            <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100 p-5">
              <div class="flex items-center justify-between mb-3 pb-3 border-b border-slate-100">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Conditions We Treat</p>
                <a href="/conditions/" class="text-xs text-teal-600 font-semibold hover:text-teal-700">View all →</a>
              </div>
              <div class="grid grid-cols-2 gap-x-6 gap-y-1">
                {conditions.map(c => (
                  <a
                    href={`/conditions/${c.slug}/`}
                    class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-600 hover:text-teal-700 hover:bg-teal-50 transition-colors"
                  >
                    <svg class="w-3 h-3 text-teal-400 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {c.shortName}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Treatments dropdown -->
        <div class="relative group/tx">
          <a
            href="/treatments/"
            class="flex items-center gap-1 px-3.5 py-2 rounded-lg text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors"
            aria-haspopup="menu"
          >
            Treatments
            <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200 group-hover/tx:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
          <!-- Treatments panel -->
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/tx:opacity-100 group-hover/tx:visible transition-all duration-150 ease-out z-50" style="min-width:340px">
            <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100 p-5">
              <div class="flex items-center justify-between mb-3 pb-3 border-b border-slate-100">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Treatments Offered</p>
                <a href="/treatments/" class="text-xs text-teal-600 font-semibold hover:text-teal-700">View all →</a>
              </div>
              <div class="flex flex-col gap-0.5">
                {treatments.map(t => (
                  <a
                    href={`/treatments/${t.slug}/`}
                    class="flex items-center gap-2.5 px-2 py-2 rounded-lg text-sm text-slate-600 hover:text-teal-700 hover:bg-teal-50 transition-colors group/item"
                  >
                    <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0" style="background:#e0f5f7">
                      <svg class="w-3.5 h-3.5 text-teal-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                      </svg>
                    </div>
                    {t.shortName}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Locations dropdown -->
        <div class="relative group/loc">
          <a
            href="/locations/"
            class="flex items-center gap-1 px-3.5 py-2 rounded-lg text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors"
            aria-haspopup="menu"
          >
            Locations
            <svg class="w-3.5 h-3.5 text-slate-400 transition-transform duration-200 group-hover/loc:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
          <!-- Locations panel -->
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/loc:opacity-100 group-hover/loc:visible transition-all duration-150 ease-out z-50" style="min-width:320px">
            <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/60 border border-slate-100 p-5">
              <div class="flex items-center justify-between mb-3 pb-3 border-b border-slate-100">
                <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">DFW Service Areas</p>
                <a href="/locations/" class="text-xs text-teal-600 font-semibold hover:text-teal-700">View all →</a>
              </div>
              <div class="grid grid-cols-2 gap-x-4 gap-y-0.5">
                {locations.map(l => (
                  <a
                    href={`/locations/${l.slug}/`}
                    class="flex items-center gap-1.5 px-2 py-1.5 rounded-lg text-sm text-slate-600 hover:text-teal-700 hover:bg-teal-50 transition-colors"
                  >
                    <svg class="w-3 h-3 text-teal-400 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                    </svg>
                    {l.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Plain links -->
        <a href="/about/" class="px-3.5 py-2 rounded-lg text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors">About</a>
        <a href="/contact/" class="px-3.5 py-2 rounded-lg text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors">Contact</a>
      </nav>

      <!-- Right: phone + CTA + hamburger -->
      <div class="flex items-center gap-3">
        <a
          href={phoneHref}
          class="hidden sm:flex items-center gap-2 text-teal-800 font-semibold text-sm hover:text-teal-600 transition-colors"
          aria-label={`Call us at ${phone}`}
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          {phone}
        </a>
        <!-- Mobile phone icon -->
        <a href={phoneHref} class="sm:hidden w-9 h-9 flex items-center justify-center rounded-full bg-teal-50 text-teal-700" aria-label={`Call ${phone}`}>
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
        </a>

        <a href="/request-appointment/" class="btn-primary text-sm py-2.5 px-5 hidden sm:inline-flex">
          Request Appointment
        </a>

        <!-- Hamburger -->
        <button
          id="menu-toggle"
          class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- ── Mobile menu (accordion-style) ── -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-slate-100 bg-white"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-0.5">

      <!-- Conditions accordion -->
      <details class="group/mob-cond">
        <summary class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 cursor-pointer list-none select-none transition-colors">
          Conditions
          <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 group-open/mob-cond:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="pl-4 pr-2 pb-2 grid grid-cols-2 gap-0.5">
          {conditions.map(c => (
            <a href={`/conditions/${c.slug}/`} class="px-3 py-2 rounded-lg text-xs text-slate-600 hover:text-teal-700 hover:bg-teal-50 transition-colors">
              {c.shortName}
            </a>
          ))}
          <a href="/conditions/" class="col-span-2 px-3 py-2 text-xs font-semibold text-teal-600 hover:text-teal-700 transition-colors">
            View all conditions →
          </a>
        </div>
      </details>

      <!-- Treatments accordion -->
      <details class="group/mob-tx">
        <summary class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 cursor-pointer list-none select-none transition-colors">
          Treatments
          <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 group-open/mob-tx:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="pl-4 pr-2 pb-2 flex flex-col gap-0.5">
          {treatments.map(t => (
            <a href={`/treatments/${t.slug}/`} class="px-3 py-2 rounded-lg text-xs text-slate-600 hover:text-teal-700 hover:bg-teal-50 transition-colors">
              {t.shortName}
            </a>
          ))}
          <a href="/treatments/" class="px-3 py-2 text-xs font-semibold text-teal-600 hover:text-teal-700 transition-colors">
            View all treatments →
          </a>
        </div>
      </details>

      <!-- Locations accordion -->
      <details class="group/mob-loc">
        <summary class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 cursor-pointer list-none select-none transition-colors">
          Locations
          <svg class="w-4 h-4 text-slate-400 transition-transform duration-200 group-open/mob-loc:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="pl-4 pr-2 pb-2 grid grid-cols-2 gap-0.5">
          {locations.map(l => (
            <a href={`/locations/${l.slug}/`} class="px-3 py-2 rounded-lg text-xs text-slate-600 hover:text-teal-700 hover:bg-teal-50 transition-colors">
              {l.name}
            </a>
          ))}
          <a href="/locations/" class="col-span-2 px-3 py-2 text-xs font-semibold text-teal-600 hover:text-teal-700 transition-colors">
            View all locations →
          </a>
        </div>
      </details>

      <!-- Plain links -->
      <a href="/about/"   class="px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors">About</a>
      <a href="/contact/" class="px-4 py-3 rounded-xl text-sm font-medium text-slate-700 hover:text-teal-700 hover:bg-teal-50 transition-colors">Contact</a>

      <!-- Mobile CTA row -->
      <div class="mt-3 pt-3 border-t border-slate-100 flex flex-col gap-2">
        <a href={phoneHref} class="btn-secondary text-center text-sm justify-center">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Call {phone}
        </a>
        <a href="/request-appointment/" class="btn-primary text-center text-sm justify-center">
          Request Appointment
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle   = document.getElementById('menu-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;

  toggle.addEventListener('click', () => {
    const nowHidden = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!nowHidden));
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });
</script>
